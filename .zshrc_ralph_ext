# Ralph-specific tools
source "$HOME/dotfile/.zshrc_claude_ext"

# Ralph API keys (general + Z.AI)
setup_ralph_tools() {
  setup_claude_tools
  load_secret ZAI_API_KEY "op://Private/Z.AI API Key/credential"
}

# Ralph agent (GitHub + Linear)
# Usage: ralph [--github <issue>|--linear <id>] [max-iterations] [model]
ralph() {
  setup_ralph_tools
  "$HOME/dotfile/ralph-agent.sh" "$@"
}

# Ralph standalone (Docker)
alias ralphx="$HOME/dotfile/afk-ralph.sh"
