# General Claude Code tools

# Load a secret from 1Password if not already set.
# Skip silently when DISABLE_SECRETS is set.
# Usage: load_secret VAR_NAME "op://vault/item/field"
load_secret() {
  local var_name="$1"
  local op_path="$2"

  [ -n "${(P)var_name}" ] && return
  [ -n "$DISABLE_SECRETS" ] && return

  export "$var_name"="$(op read "$op_path")"
}

# Shared API key setup (used by both Claude tools and Ralph scripts)
setup_claude_tools() {
  load_secret PERPLEXITY_API_KEY "op://Remote Agents/Perplexity API Key/credential"
  load_secret CONTEXT7_API_KEY "op://Remote Agents/Context7 API Key/credential"
  load_secret BROWSER_USE_API_KEY "op://Remote Agents/Browser-use API Key/credential"
  load_secret SCRAPEGRAPH_API_KEY "op://Remote Agents/ScrapegraphAI API Key/credential"
}

# Claude Code with lazy API key loading
claude() {
  setup_claude_tools
  command claude "$@"
}

# Non-interactive claude with real-time streaming output
# Usage: claude_stream [extra-flags...] "prompt"
# Alias: ccs
claude_stream() {
  claude --print --verbose --output-format stream-json "$@" \
    | grep --line-buffered '^{' \
    | jq --unbuffered -rj 'select(.type == "assistant").message.content[]? | select(.type == "text").text // empty | gsub("\n"; "\r\n") | . + "\r\n\n"'
}
alias ccs="claude_stream"

# Claude Code with GLM-4.6 via Z.AI
claudeg() {
  setup_claude_tools
  load_secret ZAI_API_KEY "op://Remote Agents/Z.AI API Key/credential"

  ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic" \
  ANTHROPIC_AUTH_TOKEN="$ZAI_API_KEY" \
  ANTHROPIC_MODEL="glm-4.6" \
  command claude "$@"
}

# Kill all Claude watcher notifications
alias claude-shh="source ~/dotfile/scripts/claude-hooks-lib.sh && kill_all_watchers"

# Browser-use wrapper with lazy API key loading
browser-use() {
  setup_claude_tools
  command browser-use "$@"
}
