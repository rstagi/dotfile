# Lazy-load pyenv (deferred ~100ms init to first use)
export PYENV_ROOT="$HOME/.pyenv"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"

# Each wrapper unsets all stubs first (prevents recursion), then inits pyenv
pyenv() {
  unfunction pyenv python python3 pip 2>/dev/null
  eval "$(command pyenv init -)"
  pyenv "$@"
}
python() {
  unfunction pyenv python python3 pip 2>/dev/null
  eval "$(command pyenv init -)"
  python "$@"
}
python3() {
  unfunction pyenv python python3 pip 2>/dev/null
  eval "$(command pyenv init -)"
  python3 "$@"
}
pip() {
  unfunction pyenv python python3 pip 2>/dev/null
  eval "$(command pyenv init -)"
  pip "$@"
}
